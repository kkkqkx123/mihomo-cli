# Mihomo 测试配置文件

# 基础配置
mixed-port: 7890
allow-lan: true
bind-address: "*"
mode: rule
log-level: info
ipv6: false
external-controller: 127.0.0.1:9090

dns:
  enable: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - '*.lan'
    - 'localhost.ptlogin2.qq.com'

  # 第一层:仅使用国内 UDP DNS
  nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 180.76.76.76

  # 第二层:国外 DNS(包括 UDP、DoH、DoT)
  fallback:
    - 8.8.8.8
    - 1.1.1.1
    - tls://8.8.8.8:853
    - https://dns.google/dns-query
    - https://cloudflare-dns.com/dns-query

  # 修正的 fallback-filter
  fallback-filter:
    geoip: true
    geoip-code: CN
    # 移除 0.0.0.0/32,只保留真正的国内 IP 段
    ipcidr:
      - 240.0.0.0/4
    domain:
      - '+.google.com'
      - '+.facebook.com'
      - '+.youtube.com'
      - '+.github.com'
      - '+.openai.com'
      - '+.cloudflare.com'

  # 添加 DNS 规则优先级
  nameserver-policy:
    'geosite:cn':
      - 223.5.5.5
      - 119.29.29.29
    'geosite:geolocation-!cn':
      - https://dns.google/dns-query
      - https://cloudflare-dns.com/dns-query

# 代理提供者 - 使用您提供的订阅链接
proxy-providers:
  my-subscription:
    type: http
    url: "xxx"
    interval: 3600
    path: ./profiles/my-subscription.yaml
    proxy: DIRECT
    header:
      User-Agent:
        - "Clash/v1.18.0"
    health-check:
      enable: true
      interval: 600
      url: https://cp.cloudflare.com/generate_204

# 代理组
proxy-groups:
  - name: PROXY
    type: select
    use:
      - my-subscription

  - name: AUTO
    type: url-test
    use:
      - my-subscription
    url: http://www.gstatic.com/generate_204
    interval: 300

# 规则
# DNS 相关规则放最前面
rules:
  - DOMAIN-SUFFIX,doh.pub,DIRECT
  - DOMAIN-SUFFIX,dns.alidns.com,DIRECT
  - DOMAIN-SUFFIX,cloudflare-dns.com,DIRECT
  - DOMAIN-SUFFIX,dns.google,DIRECT
  - DOMAIN-SUFFIX,google.com,PROXY
  - GEOIP,CN,DIRECT # 国内流量直连
  - MATCH,PROXY # 其他流量走默认代理
