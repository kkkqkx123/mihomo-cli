# 端口配置
mixed-port: 10801
port: 7890
socks-port: 7891
# redir-port: 7892    # Linux/macOS 透明代理端口，Windows 不支持
# tproxy-port: 7893   # Linux TProxy 端口，Windows 不支持

# API 控制器配置
external-controller: "127.0.0.1:9090"
# external-controller-tls: "127.0.0.1:9091"  # HTTPS API（需要配置 TLS 证书）
# external-controller-unix: "/tmp/mihomo.sock"  # Unix Socket（Linux/macOS）
external-controller-pipe: "\\\\.\\pipe\\mihomo"  # Windows 命名管道
secret: "your-secret-key"  # 请修改为安全的密钥

# CORS 配置
external-controller-cors:
  allow-origins:
    - "*"
  allow-private-network: true

# TLS 证书配置（用于 HTTPS API）
# tls:
#   certificate: "C:\\path\\to\\cert.pem"
#   private-key: "C:\\path\\to\\key.pem"
#   client-auth-type: ""
#   client-auth-cert: ""

# DoH 服务器配置
# external-doh-server: "/dns-query"

# 通用配置
allow-lan: true
bind-address: "*"
mode: rule
log-level: info
ipv6: true

# DNS 配置
dns:
  enable: true
  listen: 0.0.0.0:1053
  enhanced-mode: fake-ip
  nameserver:
    - 8.8.8.8
    - https://doh.pub/dns-query

# 代理配置（示例 - 请根据实际情况修改）
proxies:
  - name: "ss-node"
    type: ss
    server: server.com
    port: 8388
    cipher: aes-256-gcm
    password: "password"

# 代理组配置
proxy-groups:
  - name: "Proxy"
    type: select
    proxies:
      - ss-node
      - DIRECT

# 规则配置
rules:
  - DOMAIN-SUFFIX,google.com,Proxy
  - GEOIP,CN,DIRECT
  - MATCH,Proxy